name: Automated Garmin Sync

on:
  schedule:
    - cron: '30 6,7 * * 1-5'
    - cron: '0 18,19 * * 1-5'
    - cron: '30 7,8 * * 0,6'
    - cron: '0 17,18 * * 0,6'

jobs:
  sync:
    runs-on: ubuntu-latest
    
    defaults:
      run:
        shell: pwsh

    steps:
    - name: Daylight Saving Time Filter
      id: dst-filter
      run: |
        $now = [DateTime]::UtcNow
        $tzId = "Europe/London"
        
        try {
            $ukTime = [System.TimeZoneInfo]::ConvertTimeBySystemTimeZoneId($now, $tzId)
            $hour = $ukTime.Hour
            $day = [int]$ukTime.DayOfWeek 
            
            $shouldRun = $false
            if ($day -ge 1 -and $day -le 5) {
                if ($hour -eq 7 -or $hour -eq 19) { $shouldRun = $true }
            } else {
                if ($hour -eq 8 -or $hour -eq 18) { $shouldRun = $true }
            }
            
            if (-not $shouldRun) {
                Write-Host "Current UK Hour: $hour. Skipping scheduled run."
                Add-Content -Path $env:GITHUB_OUTPUT -Value "should_run=false"
                exit 0
            }
        } catch {
            Write-Host "TZ Conversion failed, proceeding anyway as fallback."
        }
        Add-Content -Path $env:GITHUB_OUTPUT -Value "should_run=true"

    - name: Checkout code
      if: steps.dst-filter.outputs.should_run == 'true'
      uses: actions/checkout@v3

    - name: Set up Python
      if: steps.dst-filter.outputs.should_run == 'true'
      uses: actions/setup-python@v4
      with:
        python-version: '3.12'

    - name: Install dependencies
      if: steps.dst-filter.outputs.should_run == 'true'
      run: |
        pip install -r requirements.txt

    - name: Restore Garmin Sessions Cache
      if: steps.dst-filter.outputs.should_run == 'true'
      uses: actions/cache/restore@v4
      with:
        path: ~/.garth_encrypted
        key: garmin-sessions-${{ github.run_id }}
        restore-keys: |
          garmin-sessions-

    - name: Decrypt Garmin Sessions
      if: steps.dst-filter.outputs.should_run == 'true'
      env:
        GARMIN_SESSION_KEY: ${{ secrets.GARMIN_SESSION_KEY }}
      run: |
        $encPath = Join-Path $HOME ".garth_encrypted/sessions.tar.enc"
        if ($env:GARMIN_SESSION_KEY -and (Test-Path $encPath)) {
            openssl enc -aes-256-cbc -d -pbkdf2 -iter 100000 -in $encPath -out sessions.tar -k $env:GARMIN_SESSION_KEY
            $garthDir = Join-Path $HOME ".garth"
            if (-not (Test-Path $garthDir)) { New-Item -ItemType Directory -Path $garthDir -Force }
            tar -xf sessions.tar -C $garthDir
            Write-Host "Session cache restored."
        }

    - name: Seed Garmin Sessions (Fallback)
      if: steps.dst-filter.outputs.should_run == 'true'
      env:
        USER1_SESSION: ${{ secrets.USER1_GARMIN_SESSION }}
        USER2_SESSION: ${{ secrets.USER2_GARMIN_SESSION }}
      run: |
        $base = Join-Path $HOME ".garth"
        if ($env:USER1_SESSION) {
            $u1 = Join-Path $base "USER1"
            if (-not (Test-Path $u1)) { New-Item -ItemType Directory -Path $u1 -Force }
            $tokenFile = Join-Path $u1 "tokens.json"
            if (-not (Test-Path $tokenFile)) { [System.IO.File]::WriteAllText($tokenFile, $env:USER1_SESSION) }
        }
        if ($env:USER2_SESSION) {
            $u2 = Join-Path $base "USER2"
            if (-not (Test-Path $u2)) { New-Item -ItemType Directory -Path $u2 -Force }
            $tokenFile = Join-Path $u2 "tokens.json"
            if (-not (Test-Path $tokenFile)) { [System.IO.File]::WriteAllText($tokenFile, $env:USER2_SESSION) }
        }

    - name: Run Sync Script
      if: steps.dst-filter.outputs.should_run == 'true'
      env:
        USER1_GARMIN_EMAIL: ${{ secrets.GARMIN_EMAIL }}
        USER1_GARMIN_PASSWORD: ${{ secrets.GARMIN_PASSWORD }}
        USER1_DRIVE_FOLDER_ID: ${{ secrets.DRIVE_FOLDER_ID }}
        USER1_NAME: ${{ secrets.USER1_NAME }}
        USER1_DOB: ${{ secrets.USER1_DOB }}
        USER1_GENDER: ${{ secrets.USER1_GENDER }}
        USER2_GARMIN_EMAIL: ${{ secrets.USER2_GARMIN_EMAIL }}
        USER2_GARMIN_PASSWORD: ${{ secrets.USER2_GARMIN_PASSWORD }}
        USER2_DRIVE_FOLDER_ID: ${{ secrets.USER2_DRIVE_FOLDER_ID }}
        USER2_NAME: ${{ secrets.USER2_NAME }}
        USER2_DOB: ${{ secrets.USER2_DOB }}
        USER2_GENDER: ${{ secrets.USER2_GENDER }}
        GOOGLE_SHEETS_CREDENTIALS: ${{ secrets.GOOGLE_SHEETS_CREDENTIALS }}
        ENABLE_SHEETS_UPDATE: ${{ secrets.ENABLE_SHEETS_UPDATE }}
        PYTHONUNBUFFERED: "1"
        LOG_LEVEL: "INFO"
      run: |
        python -m src.main

    - name: Encrypt Garmin Sessions
      if: always() && steps.dst-filter.outputs.should_run == 'true'
      env:
        GARMIN_SESSION_KEY: ${{ secrets.GARMIN_SESSION_KEY }}
      run: |
        $garthDir = Join-Path $HOME ".garth"
        if ($env:GARMIN_SESSION_KEY -and (Test-Path $garthDir)) {
            tar -cf sessions.tar -C $garthDir .
            $encDir = Join-Path $HOME ".garth_encrypted"
            if (-not (Test-Path $encDir)) { New-Item -ItemType Directory -Path $encDir -Force }
            $encFile = Join-Path $encDir "sessions.tar.enc"
            openssl enc -aes-256-cbc -salt -pbkdf2 -iter 100000 -in sessions.tar -out $encFile -k $env:GARMIN_SESSION_KEY
        }

    - name: Save Garmin Sessions Cache
      if: always() && steps.dst-filter.outputs.should_run == 'true'
      uses: actions/cache/save@v4
      with:
        path: ~/.garth_encrypted
        key: garmin-sessions-${{ github.run_id }}
